  <service name="ssh"/>
  <service name="cockpit"/>
  <port protocol="tcp" port="8443"/>
  <port protocol="tcp" port="80"/>
  <port protocol="udp" port="5060"/>
  <port protocol="tcp" port="5060"/>
  <port protocol="udp" port="10000-20000"/>
</zone>

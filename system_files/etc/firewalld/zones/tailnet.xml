<?xml version="1.0" encoding="utf-8"?>
<zone target="DROP">
  <short>tailnet</short>
  <description>Acceso administrativo y de servicios, solo via Tailscale: SSH, Cockpit (9090), Kanidm (8443), GUI FreePBX (80) y telefonia.</description>
